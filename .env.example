# Firebase 설정 (실제 값은 js/firebase-config.js에 직접 하드코딩됨)
# 이 파일은 참고용입니다

# NEIS API 키
NEIS_API_KEY=your_neis_api_key_here

# Firebase 프로젝트 ID
FIREBASE_PROJECT_ID=your_firebase_project_id

# GA4 측정 ID
GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# Sentry DSN (에러 추적)
SENTRY_DSN=https://your_sentry_dsn_here

# 개발 서버 포트
PORT=8080
