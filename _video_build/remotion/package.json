{
  "name": "eungaram-intro-video",
  "version": "1.0.0",
  "description": "은가람 중학교 1-2반 소개 영상",
  "scripts": {
    "start": "remotion studio",
    "render": "remotion render EungaramIntro --output out/eungaram-intro.mp4 --codec h264",
    "render:hq": "remotion render EungaramIntro --output out/eungaram-intro.mp4 --codec h264 --crf 16"
  },
  "dependencies": {
    "@remotion/cli": "^4.0.0",
    "remotion": "^4.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "typescript": "^5.0.0"
  }
}
