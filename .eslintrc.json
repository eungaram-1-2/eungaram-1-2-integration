{
  "env": { "browser": true, "es2021": true, "serviceworker": true },
  "extends": ["eslint:recommended"],
  "parserOptions": { "ecmaVersion": 2021, "sourceType": "script" },
  "globals": {
    "DB": "readonly",
    "firebase": "readonly",
    "navigate": "readonly",
    "escapeHtml": "readonly",
    "Security": "readonly",
    "RateLimit": "readonly",
    "CacheManager": "readonly",
    "NetworkMonitor": "readonly",
    "PWAManager": "readonly",
    "AppLogger": "readonly",
    "ErrorHandler": "readonly",
    "Analytics": "readonly",
    "renderHome": "readonly",
    "renderLunch": "readonly",
    "renderTimetable": "readonly",
    "calcDday": "readonly",
    "formatDdayLabel": "readonly",
    "currentUser": "readonly",
    "fbReady": "readonly",
    "_fbDB": "readonly",
    "closeModal": "readonly",
    "openModal": "readonly",
    "showToast": "readonly",
    "XSSProtection": "readonly",
    "CSRFProtection": "readonly",
    "CryptoUtils": "readonly",
    "ABTesting": "readonly",
    "UserFeedback": "readonly",
    "PerformanceMonitor": "readonly"
  },
  "rules": {
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }],
    "no-console": "off",
    "eqeqeq": ["error", "always"],
    "no-eval": "error",
    "no-implied-eval": "error",
    "no-new-func": "error"
  }
}
